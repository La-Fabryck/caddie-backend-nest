# https://editorconfig.org
# Prettier reads this file and merges these settings; `.prettierrc` overrides when both apply.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 140

[*.md]
trim_trailing_whitespace = false
