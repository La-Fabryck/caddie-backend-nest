{
  "name": "caddie-backend-nest",
  "version": "0.4.0",
  "private": false,
  "description": "Backend for shopping app built with NestJS, Kysely and Fastify",
  "keywords": [
    "fastify",
    "kysely",
    "nestjs",
    "nodejs",
    "rest",
    "shopping"
  ],
  "license": "AGPL-3.0-only",
  "author": "Benjamin Fabry",
  "scripts": {
    "build": "nest build",
    "start": "nest start --env-file=.env",
    "start:dev": "nest start --watch --env-file=.env",
    "start:debug": "nest start --watch --debug ${NEST_IP}:${DEBUG_PORT} --env-file=.env",
    "start:prod": "node dist/src/main.js",
    "lint": "oxfmt --check . && oxlint .",
    "format": "oxfmt --write . && oxlint --fix .",
    "db:migrate:latest": "kysely migrate latest",
    "db:migrate:make": "kysely migrate make",
    "test": "jest",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest.e2e.json --runInBand --watchAll",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest.e2e.json --coverage",
    "test:debug": "node --inspect=0.0.0.0:9230 --experimental-vm-modules -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest.js --config ./test/jest.e2e.json --runInBand --watchAll",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest.e2e.json",
    "ncu:doctor-test": "make ncu-doctor-test"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-fastify": "^11.1.21",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.5",
    "kysely": "^0.29.1",
    "kysely-ctl": "^0.21.0",
    "ms": "^2.1.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "kysely-codegen": "^0.20.0",
    "light-my-request": "^6.6.0",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "oxlint-tsgolint": "^0.22.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s?$": [
        "@swc/jest"
      ]
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
